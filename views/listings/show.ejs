<% layout("/layouts/boilerplate") %>

<!-- Mapbox CSS -->
<link href="https://api.mapbox.com/mapbox-gl-js/v3.25.0/mapbox-gl.css" rel="stylesheet" />
<script src="https://api.mapbox.com/mapbox-gl-js/v3.25.0/mapbox-gl.js"></script>

<div class="row mt-3">

  <div class="col-8 offset-3">
  <h3><%= listing.title %></h3>

  <% 
    let avg = 0;
    if (listing.reviews.length > 0) {
      let total = listing.reviews.reduce((sum, r) => sum + r.rating, 0);
      avg = total / listing.reviews.length;
    }
  %>
  <p class="rating-text">
    ⭐ <%= avg ? avg.toFixed(1) : "New" %>
    <span>(<%= listing.reviews.length %> reviews)</span>
  </p>
</div>


  <!-- IMAGE CARD -->
  <div class="card col-6 offset-3 show-card">
    <img src="<%= listing.image?.url %>" class="card-img-top show-img" />

    <div class="card-body">
      <p><strong>Hosted By:</strong> <%= listing.owner.username %></p>
      <p><%= listing.description %></p>
      <p>₹ <%= listing.price.toLocaleString("en-IN") %></p>
      <p><%= listing.location %>, <%= listing.country %></p>
    </div>
  </div>

  <% if (currUser && listing.owner._id.equals(currUser._id)) { %>
    <div class="btns">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit</a>

      <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
        <button class="btn btn-danger">Delete</button>
      </form>
    </div>
  <% } %>

  <!-- 🗺️ MAP -->
  <div class="col-6 offset-3 mt-4">
    <h4>Where you'll be</h4>

    <div id="map"
      data-lng="<%= listing.geometry?.coordinates?.[0] || 0 %>"
      data-lat="<%= listing.geometry?.coordinates?.[1] || 0 %>"
      data-title="<%= listing.title %>"
      data-location="<%= listing.location %>, <%= listing.country %>"
      data-price="₹<%= listing.price.toLocaleString('en-IN') %>"
      data-token="<%= mapToken %>"
      style="height:400px; border-radius:12px;">
    </div>
  </div>

  <!-- REVIEWS -->
  <div class="col-6 offset-3 mt-4">
    <h4>Leave a Review</h4>
    
    <form action="/listings/<%= listing._id %>/reviews" method="POST">

      <div class="star-rating">
        <span>☆</span><span>☆</span><span>☆</span><span>☆</span><span>☆</span>
      </div>

      <input type="hidden" name="review[rating]" id="rating-value">

      <textarea name="review[comment]" required></textarea>

      <button class="btn btn-dark mt-2">Submit</button>
    </form>
  </div>

  <% if (listing.reviews.length > 0) { %>
  <div class="col-6 offset-3 mt-4">
    <h4>All Reviews</h4>

    <% for (let review of listing.reviews) { %>
      <div style="border:1px solid #ddd; padding:10px; margin-bottom:10px; border-radius:8px;">

        <p><strong><%= review.author?.username || "User" %></strong></p>

        <p>
          <% for(let i = 0; i < review.rating; i++) { %> ★ <% } %>
          <% for(let i = review.rating; i < 5; i++) { %> ☆ <% } %>
        </p>

        <p><%= review.comment %></p>

        <% if (review.author && currUser && review.author._id.equals(currUser._id)) { %>
          <form method="POST"
            action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
            <button class="btn btn-danger btn-sm">Delete</button>
          </form>
        <% } %>

      </div>
    <% } %>

  </div>
<% } %>
</div>

<!-- ⭐ Styles -->
<style>
  .star-rating span {
    font-size: 24px;
    cursor: pointer;
  }

  .mapboxgl-popup-content {
    border-radius: 12px;
    padding: 10px;
  }

  .custom-marker {
    background: #FF385C;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 3px solid white;
  }
</style>

<!-- 🚀 SCRIPT -->
<script>

  // ⭐ Rating
  const stars = document.querySelectorAll(".star-rating span");
  const ratingInput = document.getElementById("rating-value");

  stars.forEach((star, index) => {
    star.addEventListener("click", () => {
      let val = index + 1;
      ratingInput.value = val;

      stars.forEach(s => s.textContent = "☆");
      for (let i = 0; i < val; i++) stars[i].textContent = "★";
    });
  });

  // 🗺️ Map
  const mapEl = document.getElementById("map");

  const lng = parseFloat(mapEl.dataset.lng);
  const lat = parseFloat(mapEl.dataset.lat);

  const token = mapEl.dataset.token;

  console.log("DEBUG:", lng, lat, token);

  mapboxgl.accessToken = token;

  // ✅ fallback if invalid
  const safeLng = (lng === 0 || isNaN(lng)) ? 77.2090 : lng; 
  const safeLat = (lat === 0 || isNaN(lat)) ?  28.6139 : lat;

  const map = new mapboxgl.Map({
    container: "map",
    style: "mapbox://styles/mapbox/streets-v12",
    center: [safeLng, safeLat],
    zoom: 10
  });

  map.addControl(new mapboxgl.NavigationControl());

  const marker = new mapboxgl.Marker()
    .setLngLat([safeLng, safeLat])
    .setPopup(
      new mapboxgl.Popup().setHTML(`
        <h5>${mapEl.dataset.title}</h5>
        <p>${mapEl.dataset.location}</p>
        <b>${mapEl.dataset.price}</b>
      `)
    )
    .addTo(map);

</script>