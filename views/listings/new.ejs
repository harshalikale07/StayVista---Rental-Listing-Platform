<% layout("/layouts/boilerplate") %>

<div class="create-page">
  <div class="create-card">

    <div class="create-header">
      <h3><i class="fa-solid fa-house-chimney-medical"></i> Create a New Listing</h3>
      <p class="text-muted">Fill in the details below to list your property on StayVista.</p>
    </div>

    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">

      <div class="mb-3">
        <label class="form-label fw-semibold">Title</label>
        <input name="listing[title]" placeholder="e.g. Cozy Beach House in Goa" type="text" class="form-control create-input" required />
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Please enter a title.</div>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Description</label>
        <textarea name="listing[description]" class="form-control create-input" rows="4" placeholder="Describe your property..." required></textarea>
        <div class="invalid-feedback">Please enter a description.</div>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Listing Image</label>
        <input name="image" class="form-control create-input" type="file" accept="image/*" required />
      </div>

      <div class="row">
        <div class="mb-3 col-md-5">
          <label class="form-label fw-semibold">Price per night (₹)</label>
          <input name="listing[price]" placeholder="e.g. 2500" type="number" class="form-control create-input" required />
          <div class="invalid-feedback">Please enter a valid price.</div>
        </div>
        <div class="mb-3 col-md-7">
          <label class="form-label fw-semibold">Country</label>
          <input name="listing[country]" placeholder="e.g. India" type="text" class="form-control create-input" required />
          <div class="invalid-feedback">Please enter a country.</div>
        </div>
      </div>

      <div class="mb-4">
        <label class="form-label fw-semibold">Location / City</label>
        <input name="listing[location]" class="form-control create-input" placeholder="e.g. Goa" type="text" required />
        <div class="invalid-feedback">Please enter a location.</div>
      </div>

      <button class="btn create-submit-btn w-100">
        <i class="fa-solid fa-plus"></i> Create Listing
      </button>

    </form>
  </div>
</div>
